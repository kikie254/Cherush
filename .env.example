NEXT_PUBLIC_SITE_URL=https://cherushguesthouse.com

# ── Supabase (public, safe to expose) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase (secret — server-side only, NEVER expose to browser) ──────────────
# Used by createAdminClient() in src/lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Analytics 4 ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Search Console (verification meta tag) ────────────────────────────
NEXT_PUBLIC_GSC_VERIFICATION=

# ── Google Maps Embed (if you use an API key) ─────────────────────────────────
# Currently using free embed URL — no key required
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Email (Nodemailer / SMTP) ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Cherush Guesthouse <bookings@cherushguesthouse.com>"
ADMIN_EMAIL=bookings@cherushguesthouse.com

# ── AI Concierge (optional — falls back to knowledge base if not set) ─────────
OPENAI_API_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=254724541664

